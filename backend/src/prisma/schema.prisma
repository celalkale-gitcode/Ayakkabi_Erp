
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. ANA ÜRÜNLER MODELİ
model Urun {
  id           String     @id @default(uuid())
  modelAdi     String     @map("model_adi")
  modelKodu    String     @unique @map("model_kodu")
  marka        String?
  kayitTarihi  DateTime   @default(now()) @map("kayit_tarihi")
  
  // İlişkiler
  varyantlar   Varyant[]

  @@map("urunler")
}

// 2. VARYANTLAR MODELİ (Renk ve Beden Bazlı Stok)
model Varyant {
  id           String     @id @default(uuid())
  urunId       String     @map("urun_id")
  renk         String
  beden        String
  sku          String     @unique
  rafKonumu    String?    @map("raf_konumu")
  stokMiktari  Int        @default(0) @map("stok_miktari")
  kayitTarihi  DateTime   @default(now()) @map("kayit_tarihi")

  // İlişkiler
  urun           Urun            @relation(fields: [urunId], references: [id], onDelete: Cascade)
  barkodlar      UrunBarkod[]
  sayimKayitlari SayimKaydi[]

  @@map("varyantlar")
}

// 3. ÜRÜN BARKODLARI MODELİ
model UrunBarkod {
  id           String     @id @default(uuid())
  varyantId    String     @map("varyant_id")
  barkod       String     @unique
  kayitTarihi  DateTime   @default(now()) @map("kayit_tarihi")

  // İlişkiler
  varyant      Varyant    @relation(fields: [varyantId], references: [id], onDelete: Cascade)

  @@map("urun_barkodlari")
}

// 4. SAYIM KAYITLARI MODELİ (Geçmiş İşlemler)
model SayimKaydi {
  id           String     @id @default(uuid())
  varyantId    String     @map("varyant_id")
  barkod       String
  miktar       Int        @default(1)
  islemTipi    String     @default("sayim") @map("islem_tipi")
  kayitTarihi  DateTime   @default(now()) @map("kayit_tarihi")

  // İlişkiler
  varyant      Varyant    @relation(fields: [varyantId], references: [id])

  @@map("sayim_kayitlari")
}
