generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Urun {
  id           String    @id @default(uuid())
  modelAdi     String    @map("model_adi")
  modelKodu    String    @unique @map("model_kodu")
  marka        String?
  kayitTarihi  DateTime  @default(now()) @map("kayit_tarihi")
  
  varyantlar   Varyant[]

  @@map("urunler")
}

model Varyant {
  id             String        @id @default(uuid())
  urunId         String        @map("urun_id")
  renk           String
  beden          String
  sku            String        @unique
  kayitTarihi    DateTime      @default(now()) @map("kayit_tarihi")

  urun           Urun          @relation(fields: [urunId], references: [id], onDelete: Cascade)
  barkodlar      UrunBarkod[]
  sayimKayitlari SayimKaydi[]
  rafStoklari    RafStok[]

  @@map("varyantlar")
}

model UrunBarkod {
  id          String    @id @default(uuid())
  varyantId   String    @map("varyant_id")
  barkod      String    @unique
  kayitTarihi DateTime  @default(now()) @map("kayit_tarihi")

  varyant     Varyant   @relation(fields: [varyantId], references: [id], onDelete: Cascade)

  @@map("urun_barkodlari")
}

model SayimKaydi {
  id          String    @id @default(uuid())
  varyantId   String    @map("varyant_id")
  konumId     String?   @map("konum_id") // SQL'e eklediğimiz yeni konum kolonu
  barkod      String
  miktar      Int       @default(1)
  islemTipi   String    @default("SAYIM") @map("islem_tipi")
  kayitTarihi DateTime  @default(now()) @map("kayit_tarihi")

  varyant     Varyant   @relation(fields: [varyantId], references: [id])
  konum       DepoKonum? @relation(fields: [konumId], references: [id], onDelete: SetNull)

  @@map("sayim_kayitlari")
}

model DepoKonum {
  id           String    @id @default(uuid())
  konumKodu    String    @unique @map("konum_kodu") 
  depoId       String    @map("depo_id")
  alan         String                               
  reyon        String                               
  sutun        Int
  kat          Int
  goz          Int
  checkDigit   String    @map("check_digit")        
  tanimliBeden String    @map("tanimli_beden")      
  isFull       Boolean   @default(false) @map("is_full") 
  kayitTarihi  DateTime  @default(now()) @map("kayit_tarihi")

  rafStoklari    RafStok[]
  sayimKayitlari SayimKaydi[] // Konumun sayım geçmişi bağı

  @@map("depo_konumlar")
}

model RafStok {
  id              String    @id @default(uuid())
  konumId         String    @map("konum_id")
  varyantId       String    @map("varyant_id")
  miktar          Int       @default(0)  
  guncellemeTarihi DateTime  @updatedAt @map("guncelleme_tarihi") 

  konum           DepoKonum @relation(fields: [konumId], references: [id], onDelete: Cascade)
  varyant         Varyant   @relation(fields: [varyantId], references: [id], onDelete: Cascade)

  @@unique([konumId, varyantId])
  @@map("raf_stoklari")
}
